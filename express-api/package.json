{
  "name": "express-api",
  "version": "1.0.0",
  "description": "Express.js API with Swagger",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "docker:build": "docker build -t express-api .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "migrate": "node scripts/migrate.js",
    "migrate:create": "node-pg-migrate create -m migrations"
  },
  "dependencies": {
    "express": "^4.18.2",
    "swagger-ui-express": "^5.0.0",
    "swagger-jsdoc": "^6.2.8",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "uuid": "^9.0.0",
    "cors": "^2.8.5",
    "yaml": "^2.3.4",
    "fs-extra": "^11.2.0",
    "pg": "^8.11.3",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}