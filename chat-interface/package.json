{
  "name": "chat-interface",
  "version": "0.1.0",
  "private": true,
  "description": "ChatGPT-like web app (Express + React + Docker) for the TalTech Agentic SD course",
  "scripts": {
    "dev:be": "cd backend && npm run dev",
    "dev:fe": "cd frontend && npm run dev",
    "build:be": "cd backend && npm run build",
    "build:fe": "cd frontend && npm run build",
    "build": "npm run build:be && npm run build:fe",
    "test:be": "cd backend && npm test",
    "test:fe": "cd frontend && npm run test:run",
    "test": "npm run test:be && npm run test:fe",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:build": "docker compose build"
  }
}
