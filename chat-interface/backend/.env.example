PORT=3001
NODE_ENV=development

# SQLite database file. In Docker this is mounted from a named volume
# (`chat-data`) at /data, so the value below is the one used in production.
DATABASE_PATH=backend/data/chat.db

# REQUIRED in production. Must be a long, random string. Local dev can leave
# this unset as long as NODE_ENV is not "production".
SESSION_SECRET=

# When "true", the session cookie is set with the Secure flag (HTTPS only).
# Leave "false" for local dev over plain HTTP; set "true" in production behind
# HTTPS.
COOKIE_SECURE=false

# Comma-separated list of allowed origins for credentialed CORS.
FRONTEND_ORIGIN=http://localhost:5173,http://localhost
