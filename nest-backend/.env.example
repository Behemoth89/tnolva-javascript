# Application
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your-db-password
DB_DATABASE=nest_backend

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=1d

# Swagger
SWAGGER_TITLE=NestJS SaaS Backend API
SWAGGER_VERSION=1.0
SWAGGER_DESCRIPTION=SaaS Platform Backend API Documentation

# API Versioning
API_VERSION_DEFAULT=1
API_VERSIONING_TYPE=url

# CORS
CORS_ORIGIN=http://localhost:5173
